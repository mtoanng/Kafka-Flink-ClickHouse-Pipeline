<?xml version="1.0" encoding="UTF-8"?>

<!-- Phase 7.1 — Dashboard rewired for IEA/APERC pillar taxonomy.
     Bilingual labels (English · Vietnamese). Status pill drives material.css
     classes .status-secure / .status-elevated / .status-stressed / .status-critical -->

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="vn.edu.ves.desktop.controller.DashboardController"
            styleClass="dashboard-root">

    <!-- ============= TOP BAR ============= -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="top-bar">
            <padding>
                <Insets bottom="12.0" left="20.0" right="20.0" top="12.0"/>
            </padding>

            <VBox spacing="2.0">
                <Label styleClass="brand" text="VES-Monitor"/>
                <Label styleClass="brand-sub" text="Energy Security Dashboard · IEA/APERC Framework"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <VBox alignment="CENTER" spacing="2.0">
                <Label styleClass="score-caption" text="Energy Security Index (ESI)"/>
                <HBox alignment="CENTER" spacing="10.0">
                    <ProgressIndicator fx:id="scoreGauge" prefHeight="60.0" prefWidth="60.0"/>
                    <VBox alignment="CENTER_LEFT" spacing="2.0">
                        <Label fx:id="lblOverallScore" styleClass="score-value" text="--"/>
                        <Label fx:id="lblScoreStatus" styleClass="score-status" text="--"/>
                    </VBox>
                </HBox>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="lblUserInfo" styleClass="user-info" text="--"/>
                <Label fx:id="lblLastRefresh" styleClass="last-refresh" text="Last refresh: --"/>
            </VBox>

            <Button fx:id="btnRefresh" onAction="#refresh" styleClass="btn-secondary" text="Refresh"/>
            <Button fx:id="btnRegions" onAction="#handleOpenRegions" styleClass="btn-secondary" text="Regions"/>
            <Button fx:id="btnAlertRules" onAction="#handleOpenAlertRules" styleClass="btn-secondary" text="Alert Rules"/>
            <Button fx:id="btnUsers" onAction="#handleOpenUsers" styleClass="btn-secondary" text="Users"/>
            <Button fx:id="btnLogout" onAction="#handleLogout" styleClass="btn-primary" text="Đăng xuất"/>
        </HBox>
    </top>

    <!-- ============= CENTER: SPLIT (tabs | recommendations) ============= -->
    <center>
        <SplitPane dividerPositions="0.78">
            <items>
                <TabPane tabClosingPolicy="UNAVAILABLE">
                    <tabs>

                        <!-- =========== PILLAR 1 — Supply Security =========== -->
                        <Tab text="Supply Security · An ninh nguồn cung">
                            <content>
                                <VBox spacing="12.0" styleClass="pillar-1">
                                    <padding>
                                        <Insets bottom="12.0" left="16.0" right="16.0" top="12.0"/>
                                    </padding>
                                    <Label styleClass="pillar-title"
                                           text="Pillar 1 — Availability (IDR · SFRI · HHI · N-1) — IEA/APERC"/>
                                    <TableView fx:id="tblPillar1" prefHeight="240.0">
                                        <columns>
                                            <TableColumn fx:id="colP1Region" prefWidth="100.0" text="Region"/>
                                            <TableColumn fx:id="colP1Fuel" prefWidth="110.0" text="Fuel"/>
                                            <TableColumn fx:id="colP1Idr" prefWidth="90.0" text="IDR"/>
                                            <TableColumn fx:id="colP1Sfri" prefWidth="110.0" text="SFRI (days)"/>
                                            <TableColumn fx:id="colP1Hhi" prefWidth="100.0" text="HHI"/>
                                            <TableColumn fx:id="colP1N1" prefWidth="110.0" text="N-1 (days)"/>
                                            <TableColumn fx:id="colP1Score" prefWidth="90.0" text="Score"/>
                                            <TableColumn fx:id="colP1Status" prefWidth="110.0" text="Status"/>
                                        </columns>
                                    </TableView>
                                    <BarChart fx:id="chartPillar1" prefHeight="260.0" legendVisible="false">
                                        <xAxis>
                                            <CategoryAxis label="Region / Fuel" side="BOTTOM"/>
                                        </xAxis>
                                        <yAxis>
                                            <NumberAxis label="SFRI — days of cover" side="LEFT"/>
                                        </yAxis>
                                    </BarChart>
                                </VBox>
                            </content>
                        </Tab>

                        <!-- =========== PILLAR 2 — Market Resilience =========== -->
                        <Tab text="Market Resilience · Khả năng chịu giá">
                            <content>
                                <VBox spacing="12.0" styleClass="pillar-2">
                                    <padding>
                                        <Insets bottom="12.0" left="16.0" right="16.0" top="12.0"/>
                                    </padding>
                                    <Label styleClass="pillar-title"
                                           text="Pillar 2 — Affordability (σ30d · price gap · β crude · affordability) — IEA/IMF"/>
                                    <TableView fx:id="tblPillar2" prefHeight="240.0">
                                        <columns>
                                            <TableColumn fx:id="colP2Fuel" prefWidth="130.0" text="Fuel"/>
                                            <TableColumn fx:id="colP2Sigma" prefWidth="110.0" text="σ_30d"/>
                                            <TableColumn fx:id="colP2Gap" prefWidth="120.0" text="Price gap %"/>
                                            <TableColumn fx:id="colP2Beta" prefWidth="100.0" text="β crude"/>
                                            <TableColumn fx:id="colP2Afford" prefWidth="140.0" text="Affordability idx"/>
                                            <TableColumn fx:id="colP2Score" prefWidth="90.0" text="Score"/>
                                            <TableColumn fx:id="colP2Status" prefWidth="110.0" text="Status"/>
                                        </columns>
                                    </TableView>
                                    <LineChart fx:id="chartPillar2" prefHeight="260.0" legendVisible="false">
                                        <xAxis>
                                            <CategoryAxis label="Fuel" side="BOTTOM"/>
                                        </xAxis>
                                        <yAxis>
                                            <NumberAxis label="σ_30d (price volatility)" side="LEFT"/>
                                        </yAxis>
                                    </LineChart>
                                </VBox>
                            </content>
                        </Tab>

                        <!-- =========== PILLAR 3 — Grid Reliability =========== -->
                        <Tab text="Grid Reliability · Độ tin cậy lưới điện">
                            <content>
                                <VBox spacing="12.0" styleClass="pillar-3">
                                    <padding>
                                        <Insets bottom="12.0" left="16.0" right="16.0" top="12.0"/>
                                    </padding>
                                    <Label styleClass="pillar-title"
                                           text="Pillar 3 — Accessibility (reserve · peak · shed prob · freq) — NERC/IEEE"/>
                                    <TableView fx:id="tblPillar3" prefHeight="240.0">
                                        <columns>
                                            <TableColumn fx:id="colP3Region" prefWidth="110.0" text="Region"/>
                                            <TableColumn fx:id="colP3Reserve" prefWidth="140.0" text="Reserve margin %"/>
                                            <TableColumn fx:id="colP3Peak" prefWidth="130.0" text="Peak factor"/>
                                            <TableColumn fx:id="colP3Shed" prefWidth="130.0" text="Shed prob"/>
                                            <TableColumn fx:id="colP3Freq" prefWidth="130.0" text="Freq stability"/>
                                            <TableColumn fx:id="colP3Score" prefWidth="90.0" text="Score"/>
                                            <TableColumn fx:id="colP3Status" prefWidth="110.0" text="Status"/>
                                        </columns>
                                    </TableView>
                                    <BarChart fx:id="chartPillar3" prefHeight="260.0" legendVisible="false">
                                        <xAxis>
                                            <CategoryAxis label="Region" side="BOTTOM"/>
                                        </xAxis>
                                        <yAxis>
                                            <NumberAxis label="Reserve margin %" side="LEFT"/>
                                        </yAxis>
                                    </BarChart>
                                </VBox>
                            </content>
                        </Tab>

                        <!-- =========== PILLAR 4 — Energy Transition =========== -->
                        <Tab text="Energy Transition · Chuyển dịch năng lượng">
                            <content>
                                <VBox spacing="12.0" styleClass="pillar-4">
                                    <padding>
                                        <Insets bottom="12.0" left="16.0" right="16.0" top="12.0"/>
                                    </padding>
                                    <Label styleClass="pillar-title"
                                           text="Pillar 4 — Acceptability (renewable% · CO2 intensity · curtailment · netzero) — IPCC AR6"/>
                                    <TableView fx:id="tblPillar4" prefHeight="240.0">
                                        <columns>
                                            <TableColumn fx:id="colP4Region" prefWidth="110.0" text="Region"/>
                                            <TableColumn fx:id="colP4Renew" prefWidth="130.0" text="Renewable %"/>
                                            <TableColumn fx:id="colP4Co2" prefWidth="140.0" text="CO2 intensity"/>
                                            <TableColumn fx:id="colP4Curtail" prefWidth="130.0" text="Curtailment %"/>
                                            <TableColumn fx:id="colP4Netzero" prefWidth="140.0" text="Net-Zero progress"/>
                                            <TableColumn fx:id="colP4Score" prefWidth="90.0" text="Score"/>
                                            <TableColumn fx:id="colP4Status" prefWidth="110.0" text="Status"/>
                                        </columns>
                                    </TableView>
                                    <PieChart fx:id="chartPillar4" prefHeight="280.0" title="Renewable share by region"/>
                                </VBox>
                            </content>
                        </Tab>

                    </tabs>
                </TabPane>

                <!-- ===== RECOMMENDATIONS SIDEBAR ===== -->
                <VBox spacing="8.0" styleClass="rec-sidebar">
                    <padding>
                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label styleClass="rec-title" text="Active recommendations"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblRecCount" styleClass="rec-count" text="0 active"/>
                    </HBox>
                    <ListView fx:id="lstRecommendations" VBox.vgrow="ALWAYS"/>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
