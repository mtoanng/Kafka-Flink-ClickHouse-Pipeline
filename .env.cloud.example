# Temporary cloud E2E template. Replace placeholders in a private ignored file.
# Never commit real values, passwords, tokens, private keys, or connector JSON.
AWS_REGION=ap-southeast-1
TF_VAR_ami_id=replace-with-an-amazon-linux-2023-ami-id
TF_VAR_key_name=replace-with-an-existing-ec2-key-pair-name
TF_VAR_ssh_cidr=203.0.113.10/32
COMPOSE_FILE=infra/docker-compose.yml
COMPOSE_PROJECT_NAME=taobao-cloud-e2e
KAFKA_ADVERTISED_EXTERNAL_HOSTNAME=replace-with-ec2-public-dns
KAFKA_EXTERNAL_PORT=9092
SCHEMA_REGISTRY_EXTERNAL_PORT=8081
KAFKA_BOOTSTRAP_SERVERS=replace-with-ec2-public-dns:9092
KAFKA_TOPIC=user-behavior-events
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=inject-at-runtime
KAFKA_SASL_PASSWORD=inject-at-runtime
KAFKA_SASL_JAAS_CONFIG=inject-at-runtime
SCHEMA_REGISTRY_URL=http://replace-with-ec2-public-dns:8081
SCHEMA_REGISTRY_BASIC_AUTH_USER_INFO=inject-at-runtime
SCHEMA_REGISTRY_API_KEY=inject-at-runtime
SCHEMA_REGISTRY_API_SECRET=inject-at-runtime
CONFLUENT_CLOUD_API_KEY=inject-at-runtime
CONFLUENT_CLOUD_API_SECRET=inject-at-runtime
CONFLUENT_KAFKA_API_KEY=inject-at-runtime
CONFLUENT_KAFKA_API_SECRET=inject-at-runtime
# External managed services; no Terraform resources are created for these.
CLICKHOUSE_ENDPOINT=https://replace-with-clickhouse-cloud-endpoint:8443
CLICKHOUSE_USER=replace-with-clickhouse-user
CLICKHOUSE_DATABASE=taobao_behavior
CLICKHOUSE_PASSWORD=inject-at-runtime
SCYLLA_HOST=replace-with-scylladb-cloud-host
SCYLLA_PORT=9042
SCYLLA_LOCAL_DATACENTER=replace-with-provider-datacenter
SCYLLA_KEYSPACE=taobao_behavior
SCYLLA_USER=inject-at-runtime
SCYLLA_PASSWORD=inject-at-runtime
GRAFANA_ENDPOINT=https://replace-with-grafana-cloud-endpoint
FLINK_CHECKPOINTING_ENABLED=true
FLINK_CHECKPOINT_INTERVAL_MS=60000
FLINK_CHECKPOINT_DIR=/var/lib/flink/checkpoints
POSTGRES_HOST=replace-with-postgresql-host
POSTGRES_PORT=5432
POSTGRES_DB=taobao_behavior
POSTGRES_USER=inject-at-runtime
POSTGRES_PASSWORD=inject-at-runtime
CDC_ENABLED=false
CONNECT_URL=http://replace-with-kafka-connect-host:8083
DEBEZIUM_CONFIG_FILE=/secure/path/postgres-behavior-rules.json
