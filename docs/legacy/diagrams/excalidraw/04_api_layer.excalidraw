      "text": "Cross-cutting concerns\n\n• OpenApiConfig\n   (Swagger UI · Bearer auth)\n• GlobalExceptionHandler\n   ApiException → 4xx/5xx JSON\n• JwtTokenProvider\n   issue / parse HS256 tokens\n   (default expiry 24h)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "containerId": "rect-18",
      "originalText": "Cross-cutting concerns\n\n• OpenApiConfig\n   (Swagger UI · Bearer auth)\n• GlobalExceptionHandler\n   ApiException → 4xx/5xx JSON\n• JwtTokenProvider\n   issue / parse HS256 tokens\n   (default expiry 24h)",
      "autoResize": true,
      "lineHeight": 1.25
    },
