      "updated": 1700000000000,
      "link": null,
      "locked": false,
      "text": "Controllers  (7 controllers · 13 endpoints)\n• AuthController         POST /api/auth/login   ·   GET /api/auth/me\n• HealthController       GET  /api/health\n• SecurityController     GET  /api/security/score   ·   /cascade-risks\n• PillarController       GET  /api/pillars/{1..4}/(supply-security | market-resilience | grid-reliability | energy-transition)\n• AlertController        GET  /api/alerts/active\n• RecommendationCtrl     GET  /api/recommendations   ·   POST /{id}/acknowledge\n• RawDataController      GET  /api/fuel-prices/latest   ·   /api/grid-load/latest",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "containerId": "rect-6",
      "originalText": "Controllers  (7 controllers · 13 endpoints)\n• AuthController         POST /api/auth/login   ·   GET /api/auth/me\n• HealthController       GET  /api/health\n• SecurityController     GET  /api/security/score   ·   /cascade-risks\n• PillarController       GET  /api/pillars/{1..4}/(supply-security | market-resilience | grid-reliability | energy-transition)\n• AlertController        GET  /api/alerts/active\n• RecommendationCtrl     GET  /api/recommendations   ·   POST /{id}/acknowledge\n• RawDataController      GET  /api/fuel-prices/latest   ·   /api/grid-load/latest",
      "autoResize": true,
      "lineHeight": 1.25
    },
