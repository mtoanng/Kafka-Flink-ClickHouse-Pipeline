# Taobao remote integration example. Keep real credentials in an ignored .env file.

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=user-behavior-events
KAFKA_CONSUMER_GROUP=taobao-stream-job
SCHEMA_REGISTRY_URL=http://localhost:8081

CLICKHOUSE_ENDPOINT=https://your-clickhouse-host:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=replace-me
CLICKHOUSE_DATABASE=taobao_behavior

# Native CQL connection settings. Set the local datacenter supplied by the
# remote cluster. Add TLS options for cqlsh through SCYLLA_CQLSH_EXTRA_ARGS.
SCYLLA_HOST=your-scylla-host
SCYLLA_PORT=9042
SCYLLA_LOCAL_DATACENTER=datacenter1
SCYLLA_USER=replace-me
SCYLLA_PASSWORD=replace-me
SCYLLA_KEYSPACE=taobao_behavior
SCYLLA_CQLSH_EXTRA_ARGS=

REPLAY_SPEED_FACTOR=0

S3_ARCHIVE_URI=s3://your-bucket/taobao/raw
FLINK_CHECKPOINTING_ENABLED=false
FLINK_CHECKPOINT_INTERVAL_MS=60000
FLINK_CHECKPOINT_DIR=
