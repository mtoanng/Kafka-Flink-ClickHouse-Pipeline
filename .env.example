# =============================================================
#  VES Real-time Fuel Price Monitoring — Example Environment
#  Copy file này sang `.env` và chỉnh giá trị nếu cần.
#  `.env` đã được .gitignore, KHÔNG commit lên repo.
# =============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=fuel_prices
POSTGRES_PORT=5432

# ── Kafka ───────────────────────────────────────────────────
KAFKA_HOST_PORT=9092
KAFKA_TOPIC=fuel-prices

# ── Flink ───────────────────────────────────────────────────
FLINK_UI_PORT=8081

# ── Metabase ────────────────────────────────────────────────
METABASE_PORT=3000

# ── Backend API (sẽ dùng ở Phase 4) ─────────────────────────
BACKEND_API_PORT=8080
JWT_SECRET=please-change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRY_HOURS=24

# ── Producer (sẽ dùng ở Phase 1+) ───────────────────────────
PRODUCER_INTERVAL_MS=10000

# ── Cloudflared Tunnel (sẽ dùng ở Phase 7) ──────────────────
# CLOUDFLARED_HOSTNAME=
