# Local core profile. Keep real credentials only in ignored .env files.
COMPOSE_FILE=infra/docker-compose.yml
COMPOSE_PROJECT_NAME=taobao-runtime
RUNTIME_PROFILE=core
START_FLINK=false
HEALTHCHECK_TIMEOUT_SECONDS=5
KAFKA_ADVERTISED_HOSTNAME=localhost
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=user-behavior-events
KAFKA_CONSUMER_GROUP=taobao-stream-job
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SASL_JAAS_CONFIG=
SCHEMA_REGISTRY_URL=http://localhost:8081/apis/ccompat/v7
SCHEMA_REGISTRY_BASIC_AUTH_USER_INFO=

CLICKHOUSE_ENDPOINT=https://your-clickhouse-host:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=inject-at-runtime
CLICKHOUSE_DATABASE=taobao_behavior
REPLAY_SPEED_FACTOR=0
FLINK_CHECKPOINTING_ENABLED=false
FLINK_CHECKPOINT_INTERVAL_MS=60000
FLINK_CHECKPOINT_DIR=
CASSANDRA_ENABLED=false
CDC_ENABLED=false
OBSERVABILITY_ENABLED=false

# Serving profile only.
CASSANDRA_PROVIDER=astra
CASSANDRA_KEYSPACE=taobao_streaming
CASSANDRA_TABLE=user_active_cart
ASTRA_DB_DATABASE_ID=
ASTRA_DB_SECURE_BUNDLE_PATH=
ASTRA_DB_APPLICATION_TOKEN=

# CDC profile only.
RULES_KAFKA_TOPIC=behavior-rules
RULES_CONSUMER_GROUP=taobao-rule-broadcast
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=taobao_behavior
POSTGRES_USER=
POSTGRES_PASSWORD=
CONNECT_URL=
DEBEZIUM_CONFIG_FILE=/secure/path/postgres-behavior-rules.json
CONNECT_GROUP_ID=taobao-debezium
CONNECT_CONFIG_TOPIC=taobao-connect-configs
CONNECT_OFFSET_TOPIC=taobao-connect-offsets
CONNECT_STATUS_TOPIC=taobao-connect-status

# Observability profile only.
GRAFANA_ENDPOINT=
CLICKHOUSE_GRAFANA_URL=
