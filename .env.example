# =============================================================
#  F1 Live Telemetry Streaming Platform — Example Environment
#  Copy file này sang `.env` và chỉnh giá trị nếu cần.
#  `.env` đã được .gitignore, KHÔNG commit lên repo.
# =============================================================

# ── Kafka (KRaft local, no Zookeeper) ───────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=car-telemetry-events
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── ClickHouse (local) ──────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=f1_telemetry

# ── Replay Engine ───────────────────────────────────────────
# Tốc độ replay: 1 = real-time, 5 = nhanh 5x, 20 = nhanh 20x
REPLAY_SPEED_FACTOR=5
# Path tới dataset (giải nén từ TracingInsights, xem scripts/fetch_f1_session.sh)
F1_DATASET_PATH=data-generators/f1-replay-engine/src/main/resources/datasets

# ── Grafana Cloud (datasource trỏ ClickHouse qua tunnel) ────
# Đăng ký account ở https://grafana.cloud (free tier)
# ClickHouse expose ra Internet qua Cloudflare Tunnel hoặc ngrok khi demo.
# Không lưu credential Grafana Cloud ở đây — cấu hình qua UI Cloud.
