# =============================================================
#  F1 Live Telemetry — Example Environment
#  Copy to .env and fill in your ClickHouse Cloud credentials.
# =============================================================

# ── Kafka (local KRaft) ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=car-telemetry-events
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── ClickHouse Cloud ────────────────────────────────────────
# Get these from your ClickHouse Cloud console:
#   https://clickhouse.cloud → Service → Connect
CLICKHOUSE_HOST=your-host.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password
CLICKHOUSE_DATABASE=f1_telemetry

# ── Replay Engine ───────────────────────────────────────────
REPLAY_SPEED_FACTOR=5
F1_DATASET_PATH=data-generators/f1-replay-engine/src/main/resources/datasets

# ── Flink Web UI ────────────────────────────────────────────
FLINK_WEB_UI_PORT=8082

# ── Redis (Leaderboard cache) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
