{
  "dashboard": {
    "title": "FORMULA 1 | Abu Dhabi Grand Prix | Race",
    "uid": "f1-live-telemetry",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "gauge",
        "title": "Live Speed (Selected Drivers)",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-f1"},
            "rawSql": "SELECT driver_number, argMax(speed, event_time) as current_speed FROM raw_telemetry WHERE driver_number IN (1, 11, 44) AND event_time >= now() - INTERVAL 30 SECOND GROUP BY driver_number",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "velocitykmh",
            "min": 0,
            "max": 350,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 200, "color": "yellow"},
                {"value": 300, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "10s Rollup: Avg/Max Speed",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-f1"},
            "rawSql": "SELECT window_start as time, driver_number, avg_speed, max_speed FROM rollup_10s WHERE $__timeFilter(window_start) ORDER BY window_start",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "velocitykmh"
          }
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Top Speed (All Time)",
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-f1"},
            "rawSql": "SELECT max(speed) as top_speed FROM raw_telemetry",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "velocitykmh",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 300, "color": "green"},
                {"value": 330, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "Throttle/Brake/RPM (Driver 1)",
        "gridPos": {"x": 6, "y": 8, "w": 18, "h": 8},
        "targets": [
          {
            "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-f1"},
            "rawSql": "SELECT event_time as time, throttle, brake, rpm FROM raw_telemetry WHERE driver_number = 1 AND $__timeFilter(event_time) ORDER BY event_time",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "rpm"},
              "properties": [{"id": "unit", "value": "rotrpm"}]
            }
          ]
        }
      }
    ]
  }
}
