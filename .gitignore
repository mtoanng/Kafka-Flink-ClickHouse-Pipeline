# =============================================================
#  F1 Live Telemetry Streaming Platform — Root .gitignore
# =============================================================

# ── Build outputs ──────────────────────────────────────────
target/
build/
out/
*.class
*.jar
*.war
*.ear
!**/.mvn/wrapper/maven-wrapper.jar

# ── IDE / Editor ───────────────────────────────────────────
.idea/
.idea./
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
*.swp
*.swo

# ── OS files ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────────────────────────
*.log
logs/
build-logs/

# ── Environment / Secrets ──────────────────────────────────
.env
.env.local
.env.*.local

# ── Docker ─────────────────────────────────────────────────
.docker/

# ── Maven Wrapper ──────────────────────────────────────────
.mvn/wrapper/maven-wrapper.properties.copy
.mvn/timing.properties

# ── F1 telemetry dataset (tải riêng, KHÔNG commit — ~150MB) ─
data-generators/f1-replay-engine/src/main/resources/datasets/

# ── Avro generated sources (từ avro-maven-plugin) ──────────
**/generated-sources/

# ── Test / Coverage ────────────────────────────────────────
coverage/
*.exec

# ── Large temporary files ──────────────────────────────────
*.tmp
*.bak
